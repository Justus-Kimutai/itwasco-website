---
import BaseLayout from "../layouts/BaseLayout.astro";
---

<BaseLayout
  title="Careers"
  description="Careers at ITWASCO - Explore job opportunities with Iten Tambach Water and Sewerage Company."
>
  <!-- Page Hero -->
  <section class="bg-gradient-to-br from-primary-50 to-white py-8 sm:py-16">
    <div class="mx-auto max-w-7xl px-4 sm:px-6 lg:px-8">
      <div class="text-center">
        <nav class="mb-2 sm:mb-4 text-sm text-gray-500">
          <a href="/" class="hover:text-primary-600">Home</a>
          <span class="mx-2">/</span>
          <span class="text-gray-900">Careers</span>
        </nav>
        <h1 class="text-3xl font-bold tracking-tight text-gray-900 sm:text-5xl">
          Careers
        </h1>
      </div>
    </div>
  </section>

  <!-- Placeholder Section -->
  <section class="py-8 sm:py-16">
    <div class="mx-auto max-w-7xl px-4 sm:px-6 lg:px-8">
      <div class="rounded-xl border border-gray-200 bg-white p-8 text-center sm:p-16">
        <p class="text-lg text-gray-600">Careers go here.</p>
      </div>
    </div>
  </section>
</BaseLayout>
