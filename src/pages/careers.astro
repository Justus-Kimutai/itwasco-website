---
import BaseLayout from "../layouts/BaseLayout.astro";

const now = new Date();
// 20 July 2026 at 5:00 PM Kenya Time (EAT = UTC+3)
const DEADLINE = new Date("2026-07-20T17:00:00+03:00");
const msLeft = DEADLINE.getTime() - now.getTime();
const expired = msLeft <= 0;
const daysLeft = Math.ceil(msLeft / (1000 * 60 * 60 * 24));
const closingSoon = !expired && daysLeft <= 5;

const badge = expired
  ? { label: "Closed", classes: "bg-gray-200 text-gray-600" }
  : closingSoon
  ? { label: `Closing Soon — ${daysLeft}d left`, classes: "bg-amber-100 text-amber-700" }
  : { label: "Open", classes: "bg-green-100 text-green-700" };

const deadlineFormatted = DEADLINE.toLocaleDateString("en-KE", {
  weekday: "long",
  year: "numeric",
  month: "long",
  day: "numeric",
});

const positions = [
  {
    id: "md",
    title: "Managing Director",
    terms: "3 Years Contract (Renewable)",
    summary:
      "Provide strategic leadership, ensure efficient operations, regulatory compliance, and quality water and sanitation service delivery. Reports to the Board of Directors and is accountable for the company's overall performance.",
    responsibilities: [
      "Provide visionary leadership and strategic direction for ITWASCO",
      "Ensure compliance with WASREB's corporate governance and regulatory standards",
      "Oversee financial management, operational efficiency, and customer service delivery",
      "Develop and implement policies, business plans, and performance targets",
      "Foster stakeholder engagement with shareholders, consumers, and regulators",
    ],
    qualifications: [
      "Bachelor's degree in Engineering, Business Administration, Finance, Environment or related field",
      "Master's degree in a relevant discipline is an added advantage",
      "At least 7 years of experience, with 3 years in senior management",
      "Strong knowledge of the water and sanitation sector",
    ],
  },
  {
    id: "technical-manager",
    title: "Technical Manager",
    terms: "3 Years Contract",
    summary:
      "Lead technical operations across water production, distribution, and Non-Revenue Water (NRW) reduction, ensuring efficient and equitable water supply within ITWASCO's service area.",
    responsibilities: [
      "Track production capacity and recommend improvements where necessary",
      "Lead meter installations, leak detection, and NRW reduction programs",
      "Develop and execute preventive maintenance plans for infrastructure and equipment",
      "Supervise and build capacity of technicians, plumbers, and support staff",
      "Analyze system data and produce weekly and monthly operational reports",
    ],
    qualifications: [
      "Diploma in Water Engineering, Civil Engineering, Mechanical, or equivalent from a recognized institution",
      "5 years' experience in water utility operations",
      "Experience managing teams and field-based operations",
      "Knowledge of pumps, pipelines, controls, metering, water treatment, and NRW management",
      "Experience in billing and revenue collection",
    ],
  },
  {
    id: "hr-manager",
    title: "Human Resource Manager",
    terms: "3 Years Contract",
    summary:
      "Provide HR services and training while maintaining relations between employees and management, fostering a harmonious working environment. Reports to the Managing Director.",
    responsibilities: [
      "Coordinate recruitment, on-boarding, orientation and induction of new employees",
      "Maintain up-to-date personnel records and HR documentation",
      "Implement staff training, development, and performance management systems",
      "Facilitate disciplinary, grievance, and employee relations processes in line with Labour laws",
      "Handle leave administration, monthly returns, and staff exit processes",
    ],
    qualifications: [
      "Bachelor's degree, Higher Diploma, or Diploma in Human Resource Management or related field",
      "Must be a member of IHRM (CHRP certification an added advantage)",
      "Minimum of 3 years' work experience and proficiency in computer applications",
      "High standards of integrity, ethical practice, and ability to work under pressure",
    ],
  },
];
---

<BaseLayout
  title="Careers"
  description="Careers at ITWASCO - Current job vacancies at Iten Tambach Water and Sewerage Company: Managing Director, Technical Manager, and Human Resource Manager."
>
  <!-- Page Hero -->
  <section class="bg-gradient-to-br from-primary-50 to-white py-8 sm:py-16">
    <div class="mx-auto max-w-7xl px-4 sm:px-6 lg:px-8">
      <div class="text-center">
        <nav class="mb-2 sm:mb-4 text-sm text-gray-500">
          <a href="/" class="hover:text-primary-600">Home</a>
          <span class="mx-2">/</span>
          <span class="text-gray-900">Careers</span>
        </nav>
        <h1 class="text-3xl font-bold tracking-tight text-gray-900 sm:text-5xl">
          Careers
        </h1>
        <p class="mx-auto mt-2 sm:mt-4 max-w-2xl text-base sm:text-lg text-gray-600">
          ITWASCO invites applications from qualified candidates for the following vacancies.
        </p>
      </div>
    </div>
  </section>

  <!-- Notice banner -->
  <section class="border-y border-amber-200 bg-amber-50 py-4">
    <div class="mx-auto max-w-7xl px-4 sm:px-6 lg:px-8">
      <div class="flex items-start gap-3 text-sm text-amber-800">
        <svg class="mt-0.5 h-5 w-5 flex-shrink-0 text-amber-600" fill="none" viewBox="0 0 24 24" stroke="currentColor">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 16h-1v-4h-1m1-4h.01M21 12a9 9 0 11-18 0 9 9 0 0118 0z" />
        </svg>
        <p>
          <strong>Deadline:</strong> All applications must be hand-delivered to ITWASCO Offices in Iten Town on or before {deadlineFormatted} at 5:00 PM. Any canvassing will lead to automatic disqualification.
        </p>
      </div>
    </div>
  </section>

  <!-- Positions List -->
  <section class="py-10 sm:py-16">
    <div class="mx-auto max-w-5xl px-4 sm:px-6 lg:px-8">
      <div class="space-y-8">
        {positions.map((position) => (
          <article id={position.id} class={`overflow-hidden rounded-2xl border shadow-sm transition-all ${expired ? "border-gray-200 bg-gray-50 opacity-75" : "border-gray-200 bg-white"}`}>

            <!-- Card header -->
            <div class={`border-b px-6 py-4 sm:px-8 ${expired ? "border-gray-200 bg-gray-100" : "border-gray-100 bg-gray-50"}`}>
              <div class="flex flex-wrap items-center justify-between gap-3">
                <span class={`inline-flex items-center rounded-full px-3 py-1 text-xs font-semibold ${badge.classes}`}>
                  {badge.label}
                </span>
                <span class="text-xs text-gray-500">{position.terms}</span>
              </div>
            </div>

            <!-- Card body -->
            <div class="px-6 py-6 sm:px-8">
              <h2 class={`mb-3 text-xl font-bold sm:text-2xl ${expired ? "text-gray-500" : "text-gray-900"}`}>
                {position.title}
              </h2>
              <p class={`mb-6 ${expired ? "text-gray-400" : "text-gray-600"}`}>{position.summary}</p>

              <div class="mb-6 grid gap-6 sm:grid-cols-2">
                <div>
                  <p class="mb-2 text-xs font-semibold uppercase tracking-wide text-gray-500">Key Responsibilities</p>
                  <ul class="space-y-2 text-sm text-gray-600">
                    {position.responsibilities.map((item) => (
                      <li class="flex items-start gap-2">
                        <svg class="mt-0.5 h-4 w-4 flex-shrink-0 text-primary-600" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7" />
                        </svg>
                        {item}
                      </li>
                    ))}
                  </ul>
                </div>
                <div>
                  <p class="mb-2 text-xs font-semibold uppercase tracking-wide text-gray-500">Minimum Qualifications</p>
                  <ul class="space-y-2 text-sm text-gray-600">
                    {position.qualifications.map((item) => (
                      <li class="flex items-start gap-2">
                        <svg class="mt-0.5 h-4 w-4 flex-shrink-0 text-primary-600" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7" />
                        </svg>
                        {item}
                      </li>
                    ))}
                  </ul>
                </div>
              </div>
            </div>
          </article>
        ))}
      </div>

      <!-- How to Apply -->
      <div class="mt-10 rounded-2xl border border-gray-200 bg-white p-6 sm:p-8">
        <h3 class="mb-3 text-lg font-bold text-gray-900">How to Apply</h3>
        <p class="mb-4 text-sm text-gray-600">
          Interested candidates should submit a cover letter, a detailed CV with three referees, copies of academic and professional certificates, and clearance certificates from EACC, HELB, KRA, CRB, and DCI (as per Chapter Six of the Constitution).
        </p>
        <div class="rounded-lg bg-gray-50 p-4 text-sm text-gray-700">
          <p class="font-semibold text-gray-900">Submit applications to:</p>
          <p class="mt-1">The Chairperson, Board of Directors</p>
          <p>Iten Tambach Water and Sewerage Company Limited (ITWASCO)</p>
          <p>P.O. Box 700-30700, Iten</p>
        </div>
      </div>
    </div>
  </section>

  <!-- CTA -->
  <section class="py-16">
    <div class="mx-auto max-w-7xl px-4 sm:px-6 lg:px-8">
      <div class="rounded-2xl bg-primary-600 px-8 py-12 text-center sm:px-12">
        <h2 class="text-2xl font-bold text-white sm:text-3xl">Questions About These Vacancies?</h2>
        <p class="mx-auto mt-4 max-w-xl text-primary-100">
          Contact us for any enquiries regarding these positions.
        </p>
        <a
          href="/contact"
          class="mt-6 inline-flex items-center justify-center rounded-lg bg-white px-6 py-3 font-semibold text-primary-600 transition-colors hover:bg-primary-50"
        >
          Contact Us
        </a>
      </div>
    </div>
  </section>
</BaseLayout>
